{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "recommendations_generate.payload.schema.json",
  "title": "recommendations_generate ingest envelope",
  "type": "object",
  "required": ["workflow_key", "run_id", "metro_id", "inputs_hash", "payload"],
  "additionalProperties": false,
  "properties": {
    "workflow_key": { "const": "recommendations_generate" },
    "run_id": { "type": "string", "minLength": 1 },
    "requested_by": { "type": "string" },
    "metro_id": { "type": "string", "minLength": 1 },
    "inputs_hash": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["recommendation_type", "title"],
      "additionalProperties": true,
      "properties": {
        "recommendation_type": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
