{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "opportunity_monitor.payload.schema.json",
  "title": "opportunity_monitor ingest envelope",
  "type": "object",
  "required": ["workflow_key", "run_id", "payload"],
  "additionalProperties": false,
  "properties": {
    "workflow_key": { "const": "opportunity_monitor" },
    "run_id": { "type": "string", "minLength": 1 },
    "requested_by": { "type": "string" },
    "opportunity_id": { "type": "string" },
    "org_id": { "type": ["string", "null"] },
    "org_name": { "type": ["string", "null"] },
    "payload": {
      "type": "object",
      "required": ["result"],
      "additionalProperties": false,
      "properties": {
        "result": {
          "type": "object",
          "required": ["signals"],
          "additionalProperties": false,
          "properties": {
            "signals": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["signal_type"],
                "additionalProperties": true,
                "properties": {
                  "signal_type": { "type": "string" },
                  "signal_value": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                  "source_url": { "type": "string" },
                  "detected_at": { "type": "string", "format": "date-time" }
                }
              }
            }
          }
        }
      }
    }
  }
}
