  "section_3_workflows": {
    "activation": {
      "primary_pages": ["/admin/activation", "/operator/nexus/arrival"],
      "core_actions": ["schedule_guided_session", "complete_checklist_items", "track_readiness_score", "operator_impersonation"],
      "ai_involvement": "None directly — checklist templates are static; operator provides human guidance during sessions."
    },
    "qa_and_stability": {
      "primary_pages": ["/operator/nexus (QA section)", "/operator/console"],
      "core_actions": ["run_playwright_test_suites", "generate_repair_packs", "review_test_results", "batch_fix_generation"],
      "ai_involvement": "Repair Pack generation uses AI to propose code fixes from test failures."
    },
    "migration": {
      "primary_pages": ["/relatio", "/operator/nexus (Migration section)"],
      "core_actions": ["csv_import", "connector_health_check", "migration_history_review", "data_mapping"],
      "ai_involvement": "AI-assisted field mapping during CSV import; connector status monitoring."
    },
    "expansion": {
      "primary_pages": ["/operator/nexus (Expansion section)", "/metros", "/momentum"],
      "core_actions": ["monitor_metro_growth_signals", "identify_expansion_candidates", "track_momentum_rankings"],
      "ai_involvement": "NRI generates momentum signals and metro narrative recommendations via n8n workflows."
    },
    "communio": {
      "primary_pages": ["/communio"],
      "core_actions": ["create_group", "invite_tenants", "configure_sharing_levels", "share_events_and_signals", "governance_flag_review"],
      "ai_involvement": "None — Communio is a human-driven collaboration layer."
    },
    "outreach": {
      "primary_pages": ["/campaigns"],
      "core_actions": ["create_email_campaign", "select_recipients", "send_via_gmail", "track_delivery_status", "manage_unsubscribes"],
      "ai_involvement": "Campaign suggestions generated by NRI based on relationship signals; AI drafts subject lines and body templates."
    },
    "scheduling": {
      "primary_pages": ["/calendar", "/events", "/activities"],
      "core_actions": ["log_activities", "schedule_events", "discover_local_events", "google_calendar_sync", "track_attendance"],
      "ai_involvement": "Local Pulse event discovery uses Firecrawl + n8n; AI suggests follow-up activities."
    },
    "narrative_intelligence": {
      "primary_pages": ["/testimonium", "/narratives", "/intel-feed", "/momentum"],
      "core_actions": ["generate_metro_narratives", "detect_drift", "produce_reconnection_signals", "create_story_exports", "track_momentum"],
      "ai_involvement": "Core NRI engine — all narrative generation, drift detection, momentum scoring, and recommendation production runs through n8n workflows calling LLMs. AI assists but never replaces human voice."
    }
  },

  "section_4_voice_note_system": {
    "storage_behavior": {
      "audio_storage": "Supabase Storage bucket 'voice-notes'; configurable via tenant_voice_settings",
      "retention_policy": "Admins can disable audio retention (store_audio=false) to keep transcripts only",
      "file_format": "WebM/MP3 captured from browser MediaRecorder API",
      "privacy": "Audio scoped to tenant_id + user_id; RLS enforced"
    },
    "transcription_pipeline": {
      "edge_function": "voice-transcribe",
      "model": "Gemini 2.5 Flash via Lovable AI gateway",
      "flow": "1) Audio uploaded to storage → 2) Edge function invoked with file path → 3) Gemini transcribes → 4) Transcript stored in voice_notes table → 5) Activity auto-created",
      "language_support": "Auto-detected by Gemini; primarily English",
      "error_handling": "Failed transcriptions stored with status='failed' and error message retained"
    },
    "activity_injection": {
      "target_table": "activities",
      "activity_type": "Visit Note",
      "linked_fields": ["opportunity_id", "contact_id", "metro_id"],
      "notes_field": "Contains full transcript text",
      "nri_visibility": "Injected activities are immediately available for NRI narrative ingestion via standard testimonium event pipeline"
    }
  },

  "section_5_operator_nexus_workflows": {
    "new_arrivals": {
      "purpose": "Stewardship moment for new tenant onboarding — calm, guided awareness",
      "data_sources": ["tenants", "operator_tenant_stats", "testimonium_events", "guided_activation_sessions"],
      "primary_actions": ["view_arrival_summary", "follow_guidance_checklist", "login_as_tenant_admin", "open_activation_session", "review_7_day_timeline"],
      "alerts_or_signals": ["tenant_created_within_48h", "status_awaiting_activation", "operator_sponsored_badge", "settling_in / needs_guidance / ready_for_expansion badges"]
    },
    "activation": {
      "purpose": "Track and manage guided activation sessions and readiness checklists",
      "data_sources": ["activation_checklists", "activation_checklist_items", "activation_sessions", "activation_offers"],
      "primary_actions": ["schedule_session", "complete_checklist_items", "track_readiness_score", "manage_session_status"],
      "alerts_or_signals": ["pending_sessions", "low_readiness_score", "overdue_checklist_items"]
    },
    "qa": {
      "purpose": "Automated system stability monitoring and self-healing repair generation",
      "data_sources": ["qa_test_results (external)", "automation_runs"],
      "primary_actions": ["trigger_test_suite", "review_failures", "generate_repair_pack", "batch_apply_fixes"],
      "alerts_or_signals": ["test_failure_count", "critical_regression_detected"]
    },
    "migrations": {
      "purpose": "Monitor CRM migration and connector health for onboarding tenants",
      "data_sources": ["automation_runs", "tenant connector configs"],
      "primary_actions": ["check_connector_health", "review_migration_history", "open_migration_harness"],
      "alerts_or_signals": ["connector_offline", "migration_stalled", "data_mapping_incomplete"]
    },
    "support": {
      "purpose": "Human-centered feedback triage and care — not a ticket system",
      "data_sources": ["feedback submissions", "testimonium_events"],
      "primary_actions": ["review_feedback", "respond_to_tenant", "escalate_to_care"],
      "alerts_or_signals": ["unread_feedback", "sentiment_drift", "repeated_friction_signals"]
    },
    "expansion": {
      "purpose": "Monitor metro growth signals and identify expansion opportunities",
      "data_sources": ["metro_momentum_signals", "operator_tenant_stats", "ai_recommendations"],
      "primary_actions": ["review_growth_signals", "identify_expansion_metros", "track_regional_momentum"],
      "alerts_or_signals": ["high_momentum_metro", "expansion_candidate_detected", "regional_growth_trend"]
    },
    "knowledge": {
      "purpose": "Internal playbook and procedure management for operator reference",
      "data_sources": ["ai_knowledge_documents", "ai_knowledge_document_versions"],
      "primary_actions": ["browse_playbooks", "edit_knowledge_articles", "version_history_review"],
      "alerts_or_signals": ["outdated_document", "new_version_published"]
    }
  }
}
